SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Railway sets DATABASE_URL automatically)
DATABASE_URL=sqlite:///db.sqlite3

# Sports data API keys
FOOTBALL_DATA_API_KEY=your-football-data-org-key

# Coinbase prediction markets (Advanced Trade API)
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_API_SECRET=your-coinbase-api-secret

# Optional: ESPN API (no key required for most endpoints)
ESPN_API_BASE=https://site.api.espn.com/apis/site/v2/sports

# Kalshi prediction markets API
KALSHI_API_KEY=your-kalshi-api-key
